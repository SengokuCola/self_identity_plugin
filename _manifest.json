{
  "manifest_version": 2,
  "version": "1.3.0",
  "name": "自我信息插件 (Self Identity Plugin)",
  "description": "为 Bot 提供自我信息检索、人设图库浏览、自我图片与 QQ 头像获取能力",
  "author": {
    "name": "SengokuCola",
    "url": "https://github.com/SengokuCola"
  },
  "license": "MIT",
  "plugin_type": "chat",
  "urls": {
    "repository": "https://github.com/SengokuCola/self_identity_plugin",
    "homepage": "https://github.com/SengokuCola/self_identity_plugin",
    "documentation": "https://github.com/SengokuCola/self_identity_plugin/blob/main/README.md",
    "issues": "https://github.com/SengokuCola/self_identity_plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.0.0"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "config.get",
    "llm.generate",
    "llm.get_available_models",
    "message.get_by_id"
  ],
  "display": {
    "icon": {
      "type": "emoji",
      "value": "🪞",
      "background": "#E8F0F7"
    }
  },
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "sengokucola.self-identity-plugin"
}
